ENV=development
FRONTEND_ORIGIN=http://localhost:3000

JWT_SECRET=change-this-to-a-random-string

# Leave empty to run in stub mode (no real LLM calls, placeholder responses).
# Add your Groq key here later: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Leave empty to use the in-memory store (resets on restart). Add your
# MongoDB Atlas connection string when ready.
MONGO_URI=
MONGO_DB_NAME=customer_support_ai

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTORSTORE_DIR=./vectorstore_data
KNOWLEDGE_BASE_DIR=../knowledge_base
RETRIEVAL_TOP_K=3
